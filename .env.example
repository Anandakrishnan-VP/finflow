# ──────────────────────────────────────────────────────────────────────────────
# FinFlow — Environment Configuration
# Copy this file to .env and fill in all values before running docker compose.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Use any strong password. Must match across all containers.
POSTGRES_PASSWORD=changeme_strong_password

# ── Graph Database ────────────────────────────────────────────────────────────
NEO4J_PASSWORD=changeme_neo4j_password

# ── JWT Secret ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=changeme_generate_with_openssl_rand_hex_32

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Option A: Offline template mode (no API key required — recommended for first run)
LLM_PROVIDER=template
LLM_MODEL=llama-3.1-8b-instant
GROQ_API_KEY=not_needed_for_template_mode

# Option B: Live Groq API (free key at https://console.groq.com)
# LLM_PROVIDER=groq
# LLM_MODEL=llama-3.1-8b-instant
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# ── Timestamp Authority ───────────────────────────────────────────────────────
TSA_URL=https://freetsa.org/tsr

# ── Admin Account ─────────────────────────────────────────────────────────────
# Password for the initial admin user created on first run
ADMIN_INITIAL_PASSWORD=changeme_admin_password

# ── Host Development Only (not used by Docker) ───────────────────────────────
# Only needed if running uvicorn directly outside Docker.
# Replace changeme_strong_password with your POSTGRES_PASSWORD value above.
DATABASE_URL=postgresql+asyncpg://finflow:changeme_strong_password@localhost:5432/finflow
